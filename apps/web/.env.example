# apps/web environment — copy to .env for local dev and fill in.
# These are VITE_-prefixed, so Vite inlines them into the client bundle at
# BUILD time (import.meta.env.VITE_*). They are NOT secrets — anything here ends
# up in the public JS bundle. Never put tokens or keys behind a VITE_ name.
#
# Both are optional: the Settings → About links only render when set.
# In CI/production these come from GitHub Actions Variables (see deploy.yml),
# not the Cloudflare Pages dashboard — the build runs in Actions, not on Pages.

# Link back to your portfolio site (shown as "Portfolio ↗" in Settings → About).
VITE_PORTFOLIO_URL=https://your-portfolio.example

# Contact address (rendered as a mailto: link in Settings → About).
VITE_CONTACT_EMAIL=you@example.com
